{
    "name": "chromiumly",
    "version": "5.2.1",
    "description": "A lightweight Typescript library that interacts with Gotenberg's different modules to convert a variety of document formats to PDF files.",
    "main": "dist/main.js",
    "types": "dist/main.d.ts",
    "files": [
        "dist"
    ],
    "repository": {
        "type": "git",
        "url": "https://github.com/cherfia/chromiumly.git"
    },
    "author": "Taha Cherfia <taha.cherfia@gmail.com>",
    "license": "MIT",
    "packageManager": "yarn@4.17.0",
    "engines": {
        "node": ">=18.x"
    },
    "keywords": [
        "gotenberg",
        "chromium",
        "LibreOffice",
        "screenshots",
        "html",
        "markdown",
        "pdf",
        "docx",
        "pptx",
        "xlsx"
    ],
    "scripts": {
        "clean": "rm -rf dist build",
        "lint": "eslint src/",
        "build": "yarn clean && tsc -p tsconfig.json",
        "test": "jest --runInBand --ci --coverage --reporters=default --reporters=jest-junit",
        "commit": "git-cz",
        "format": "yarn prettier . -w",
        "release": "release-it",
        "prepare": "husky"
    },
    "config": {
        "commitizen": {
            "path": "@commitlint/cz-commitlint"
        }
    },
    "devDependencies": {
        "@babel/core": "7.29.7",
        "@babel/preset-typescript": "7.29.7",
        "@commitlint/cli": "^21.0.0",
        "@commitlint/config-conventional": "^21.0.0",
        "@commitlint/cz-commitlint": "^21.0.0",
        "@eslint/eslintrc": "^3.3.5",
        "@eslint/js": "^10.0.1",
        "@release-it/conventional-changelog": "11.0.1",
        "@types/config": "4.4.0",
        "@types/dotenv": "8.2.3",
        "@types/jest": "30.0.0",
        "@types/node": "24.13.2",
        "@typescript-eslint/eslint-plugin": "8.61.1",
        "@typescript-eslint/parser": "8.61.1",
        "commitizen": "4.3.2",
        "eslint": "10.2.0",
        "eslint-config-prettier": "^10.1.8",
        "globals": "^17.5.0",
        "husky": "^9.1.7",
        "inquirer": "13",
        "jest": "30.4.2",
        "jest-junit": "17.0.0",
        "lint-staged": "^17.0.0",
        "prettier": "3.8.4",
        "release-it": "20.2.0",
        "ts-jest": "29.4.11",
        "ts-node": "10.9.2",
        "tslib": "2.8.1",
        "typescript": "6.0.3"
    },
    "optionalDependencies": {
        "config": "4.x",
        "dotenv": "17.x"
    },
    "resolutions": {
        "conventional-changelog-conventionalcommits": "9.3.1"
    },
    "lint-staged": {
        "**/*": "yarn prettier --write --ignore-unknown"
    }
}
